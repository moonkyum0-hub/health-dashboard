// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  role         String?
  accountType  String       @default("USER") // USER | EXPERT | ADMIN
  createdAt    DateTime     @default(now())
  dailyLogs    DailyLog[]
  aiFeedbacks  AiFeedback[]
  routines     Routine[]
  customExercises ExerciseCatalog[]
  knowledgeCards  KnowledgeCard[]
  questions       Question[]
  answers         Answer[]
}

model KnowledgeCard {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  summary   String
  body      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  images    KnowledgeCardImage[]
}

model KnowledgeCardImage {
  id      String        @id @default(cuid())
  cardId  String
  card    KnowledgeCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  url     String
  caption String?
  order   Int
}

model Question {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String
  createdAt DateTime @default(now())
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  expertId   String
  expert     User     @relation(fields: [expertId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())
}

model ExerciseCatalog {
  id                 String   @id @default(cuid())
  name               String   @unique
  category           String // CORE | UPPER | LOWER | FLEXIBILITY | CARDIO
  description        String
  benefit            String
  cue                String
  defaultDurationMin Int?
  defaultSetsReps    String?
  videoUrl           String?
  poseStart          String?
  poseEnd            String?
  createdById        String?
  createdBy          User?    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  routineItems       RoutineItem[]
}

model Routine {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  days      String // comma-separated weekday numbers, e.g. "1,3,5"
  items     RoutineItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model RoutineItem {
  id                String           @id @default(cuid())
  routineId         String
  routine           Routine          @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseCatalogId String?
  exerciseCatalog   ExerciseCatalog? @relation(fields: [exerciseCatalogId], references: [id])
  customName        String?
  order             Int
  durationMin       Int?
  setsReps          String?
}

model DailyLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime
  dayOfWeek  String
  routine    String // MWF | TTS | REST

  bedTime      String?
  wakeTime     String?
  sleepHours   Float?
  sleepQuality Int?

  energyMorning   Int?
  energyAfternoon Int?
  energyEvening   Int?

  studyFocusScore   Int?
  studyFocusMinutes Int?
  reactionTimeMs    Float?

  totalExerciseMin Int?
  overallRPE       Int?
  exerciseNotes    String?

  exercises    ExerciseLog[]
  meals        MealLog[]
  aiFeedbacks  AiFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model ExerciseLog {
  id          String   @id @default(cuid())
  dailyLogId  String
  dailyLog    DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  name        String
  region      String // CORE | UPPER | LOWER | FLEXIBILITY | CARDIO
  durationMin Int?
  setsReps    String?
  rpe         Int?
  completed   Boolean  @default(true)
  pain        Boolean  @default(false)
  notes       String?
}

model MealLog {
  id         String   @id @default(cuid())
  dailyLogId String
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  mealType   String
  time       String?
  items      String
  notes      String?
}

model AiFeedback {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLogId  String?
  dailyLog    DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  type        String // DAILY | WEEKLY | REGION | CORRELATION
  periodStart DateTime?
  periodEnd   DateTime?
  content     String
  createdAt   DateTime  @default(now())
}
